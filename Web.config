<configuration>
	<appSettings>
		<add key="PinewoodDB" value="C:\PinewoodDerby\Pinewood.mdb" />
    <add key="Title" value="Pinewood Derby Site" />
	</appSettings>
  <system.web>
    <compilation debug="true" defaultLanguage="c#" targetFramework="4.0" />
    <customErrors mode="Off" />
  </system.web>
    <system.webServer>
        <defaultDocument>
            <files>
                <add value="Cars.aspx" />
            </files>
        </defaultDocument>
    </system.webServer>
</configuration>